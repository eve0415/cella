---
source: crates/cella-features/src/dockerfile.rs
expression: result
---
ARG _DEV_CONTAINERS_BASE_IMAGE=ubuntu:22.04
ARG _DEV_CONTAINERS_IMAGE_USER=root
ARG _DEV_CONTAINERS_FEATURE_CONTENT_SOURCE

FROM ubuntu:22.04 AS dev_containers_target_stage

# Feature: node (ghcr.io/devcontainers/features/node:1)
COPY --chown=root:root node/ /tmp/dev-container-features/node/
RUN chmod +x /tmp/dev-container-features/node/install.sh \
    && cd /tmp/dev-container-features/node \
    && ./install.sh

# Cleanup
RUN rm -rf /tmp/dev-container-features
