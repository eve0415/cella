impl DevContainerCommonUserEnvProbe {
    pub fn validate(
        value: &serde_json::Value,
        path: &str,
    ) -> Result<Self, Vec<ValidationError>> {
        let s = value
            .as_str()
            .ok_or_else(|| {
                vec![
                    ValidationError { path : path.to_string(), message :
                    "expected string".to_string(), kind : ValidationErrorKind::TypeError,
                    }
                ]
            })?;
        match s {
            "none" => Ok(Self::None),
            "loginShell" => Ok(Self::LoginShell),
            "loginInteractiveShell" => Ok(Self::LoginInteractiveShell),
            "interactiveShell" => Ok(Self::InteractiveShell),
            other => {
                Err(
                    vec![
                        ValidationError { path : path.to_string(), message :
                        format!("invalid value \"{other}\", expected one of: {}",
                        "none, loginShell, loginInteractiveShell, interactiveShell"),
                        kind : ValidationErrorKind::InvalidEnumValue, }
                    ],
                )
            }
        }
    }
}
