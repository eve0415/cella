impl MountType {
    pub fn validate(
        value: &serde_json::Value,
        path: &str,
    ) -> Result<Self, Vec<ValidationError>> {
        let s = value
            .as_str()
            .ok_or_else(|| {
                vec![
                    ValidationError { path : path.to_string(), message :
                    "expected string".to_string(), kind : ValidationErrorKind::TypeError,
                    }
                ]
            })?;
        match s {
            "bind" => Ok(Self::Bind),
            "volume" => Ok(Self::Volume),
            other => {
                Err(
                    vec![
                        ValidationError { path : path.to_string(), message :
                        format!("invalid value \"{other}\", expected one of: {}",
                        "bind, volume"), kind : ValidationErrorKind::InvalidEnumValue, }
                    ],
                )
            }
        }
    }
}
impl Mount {
    pub fn validate(
        value: &serde_json::Value,
        path: &str,
    ) -> Result<Self, Vec<ValidationError>> {
        let obj = value
            .as_object()
            .ok_or_else(|| {
                vec![
                    ValidationError { path : path.to_string(), message :
                    "expected object".to_string(), kind : ValidationErrorKind::TypeError,
                    }
                ]
            })?;
        let mut errors: Vec<ValidationError> = Vec::new();
        if !obj.contains_key("target") {
            errors
                .push(ValidationError {
                    path: format!("{path}/{}", "target"),
                    message: format!("missing required field: {}", "target"),
                    kind: ValidationErrorKind::MissingRequired,
                });
        }
        if !obj.contains_key("type") {
            errors
                .push(ValidationError {
                    path: format!("{path}/{}", "type"),
                    message: format!("missing required field: {}", "type"),
                    kind: ValidationErrorKind::MissingRequired,
                });
        }
        let source = if let Some(v) = obj.get("source") {
            let field_path = format!("{path}/{}", "source");
            match v
                .as_str()
                .map(String::from)
                .ok_or_else(|| {
                    vec![
                        ValidationError { path : field_path.to_string(), message :
                        "expected string".to_string(), kind :
                        ValidationErrorKind::TypeError, }
                    ]
                })
            {
                Ok(val) => Some(val),
                Err(mut e) => {
                    errors.append(&mut e);
                    None
                }
            }
        } else {
            None
        };
        let target = if let Some(v) = obj.get("target") {
            let field_path = format!("{path}/{}", "target");
            match v
                .as_str()
                .map(String::from)
                .ok_or_else(|| {
                    vec![
                        ValidationError { path : field_path.to_string(), message :
                        "expected string".to_string(), kind :
                        ValidationErrorKind::TypeError, }
                    ]
                })
            {
                Ok(val) => Some(val),
                Err(mut e) => {
                    errors.append(&mut e);
                    None
                }
            }
        } else {
            None
        };
        let r#type = if let Some(v) = obj.get("type") {
            let field_path = format!("{path}/{}", "type");
            match MountType::validate(v, &field_path) {
                Ok(val) => Some(val),
                Err(mut e) => {
                    errors.append(&mut e);
                    None
                }
            }
        } else {
            None
        };
        for key in obj.keys() {
            if !["source", "target", "type"].contains(&key.as_str()) {
                errors
                    .push(ValidationError {
                        path: format!("{path}/{key}"),
                        message: format!("unknown field: {key}"),
                        kind: ValidationErrorKind::UnknownField,
                    });
            }
        }
        if errors.is_empty() {
            Ok(Self {
                source,
                target: target.unwrap(),
                r#type: r#type.unwrap(),
            })
        } else {
            Err(errors)
        }
    }
}
impl BuildOptionsCacheFrom {
    pub fn validate(
        value: &serde_json::Value,
        path: &str,
    ) -> Result<Self, Vec<ValidationError>> {
        if value.is_string() {
            if let Ok(val) = value
                .as_str()
                .map(String::from)
                .ok_or_else(|| {
                    vec![
                        ValidationError { path : path.to_string().to_string(), message :
                        "expected string".to_string(), kind :
                        ValidationErrorKind::TypeError, }
                    ]
                })
            {
                return Ok(BuildOptionsCacheFrom::String(val));
            }
        }
        if value.is_array() {
            if let Ok(val) = (|| -> Result<_, Vec<ValidationError>> {
                let arr = value
                    .as_array()
                    .ok_or_else(|| {
                        vec![
                            ValidationError { path : path.to_string().to_string(),
                            message : "expected array".to_string(), kind :
                            ValidationErrorKind::TypeError, }
                        ]
                    })?;
                let mut result = Vec::new();
                let mut errs: Vec<ValidationError> = Vec::new();
                for (i, item) in arr.iter().enumerate() {
                    let item_path = format!("{}/{i}", path.to_string());
                    match item
                        .as_str()
                        .map(String::from)
                        .ok_or_else(|| {
                            vec![
                                ValidationError { path : item_path.to_string(), message :
                                "expected string".to_string(), kind :
                                ValidationErrorKind::TypeError, }
                            ]
                        })
                    {
                        Ok(val) => result.push(val),
                        Err(mut e) => errs.append(&mut e),
                    }
                }
                if errs.is_empty() { Ok(result) } else { Err(errs) }
            })() {
                return Ok(BuildOptionsCacheFrom::Array(val));
            }
        }
        Err(
            vec![
                ValidationError { path : path.to_string(), message :
                "value does not match any expected type".to_string(), kind :
                ValidationErrorKind::TypeError, }
            ],
        )
    }
}
